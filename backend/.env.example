# TransitionSmart Review Studio — backend env template.
# Copy this to `.env` in this same directory and paste your own values.
# Never commit the real .env — .gitignore already excludes it.

# ── Server ──
API_HOST=0.0.0.0
API_PORT=8004
CORS_ORIGINS=http://localhost:5190

# ── Azure Blob (video + document storage) ──
BLOB_CONNECTION_STRING=DefaultEndpointsProtocol=https;AccountName=REPLACE;AccountKey=REPLACE;EndpointSuffix=core.windows.net
BLOB_CONTAINER=video-demo
# Prefix so this app's blobs don't collide with other assets in the container.
BLOB_PREFIX=sop-editor

# ── Azure OpenAI (GPT-4o for block rewrites + agentic RAG chat) ──
AZURE_OPENAI_ENDPOINT=https://your-resource.cognitiveservices.azure.com/
AZURE_OPENAI_KEY=REPLACE
AZURE_OPENAI_DEPLOYMENT=gpt-4o
AZURE_OPENAI_API_VERSION=2025-01-01-preview
LLM_TEMPERATURE=0.2
LLM_MAX_TOKENS=1200

# ── Gemini (video understanding + semantic frame search) ──
GEMINI_MODEL=gemini-2.5-flash
GEMINI_API_KEY=REPLACE

# ── Qdrant (optional — RAG chat falls back to a local in-memory index) ──
QDRANT_URL=https://your-cluster.eu-west-2-0.aws.cloud.qdrant.io
QDRANT_API_KEY=REPLACE
QDRANT_COLLECTION_PREFIX=video-sop-

# ── Azure OpenAI embedding deployment (must match ingest-time model) ──
AZURE_OPENAI_EMBEDDING_DEPLOYMENT=text-embedding-3-large
AZURE_OPENAI_EMBEDDING_DIMENSIONS=3072
